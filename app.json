{
  "expo": {
    "name": "Vlog",
    "slug": "vlog-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vlogapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Record short vlog clips.",
        "NSMicrophoneUsageDescription": "Capture audio with your vlog clips.",
        "NSPhotoLibraryUsageDescription": "Import photos and videos, and save exported vlogs.",
        "NSPhotoLibraryAddUsageDescription": "Save exported vlog clips to your camera roll."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFA",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FAFAFA"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Vlog to record clips.",
          "microphonePermission": "Allow Vlog to record audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Vlog to save and import media.",
          "savePhotosPermission": "Allow Vlog to save exported clips.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vlog to import from your camera roll."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
